# .swiftformat

# Swift 버전 명시
--swiftversion 5.10

# 제외 경로
--exclude .build,Pods,.swiftpm

# ── 들여쓰기 ──
--indent 4
--tabwidth 4
--indentcase false          # switch case 들여쓰기 여부

# ── 줄바꿈 ──
--linebreaks lf
--maxwidth 120              # 최대 줄 길이 (SwiftLint와 맞춤)
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--closingparen balanced

# ── 공백 ──
--trimwhitespace always
--ranges no-space           # 1...3 (공백 없음)

# ── self ──
--self remove               # 불필요한 self 제거

# ── import ──
--importgrouping testable-bottom  # @testable import는 하단

# ── 기타 ──
--header ignore             # 파일 헤더 주석 무시
--semicolons never          # 세미콜론 제거
--commas always             # trailing comma 추가
--stripunusedargs closure-only  # 미사용 클로저 인자만 제거

# ── 활성화할 opt-in 규칙들 ──
--enable isEmpty
--enable sortImports
--enable wrapConditionalBodies
--enable blankLinesBetweenImports
--enable docComments
